# ===========================================
# Reservas Pousada - Production Environment
# ===========================================

# PostgreSQL Database
POSTGRES_USER=reservas
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=reservas_pousada

# Better Auth (REQUIRED)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32

# Google OAuth (Optional - leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===========================================
# DO NOT MODIFY BELOW (auto-configured)
# ===========================================
# These are set in docker-compose.yml:
# - DATABASE_URL (constructed from POSTGRES_* vars)
# - BETTER_AUTH_URL (https://api-reservas.pgdev.com.br)
# - CORS_ORIGIN (https://reservas.pgdev.com.br)
# - NEXT_PUBLIC_API_URL (build arg)
