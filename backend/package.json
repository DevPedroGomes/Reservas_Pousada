{
  "name": "pousada-reservas-backend",
  "version": "2.0.0",
  "description": "Sistema de Gerenciamento de Reservas para Pousada - PostgreSQL + Better Auth",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch server.ts",
    "build": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "auth:generate": "npx @better-auth/cli@latest generate",
    "backup": "node --import dotenv/config backup.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "pousada",
    "reservas",
    "hospedagem",
    "node",
    "express",
    "postgresql",
    "drizzle",
    "better-auth"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-auth": "^1.2.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.45.1",
    "express": "^4.21.0",
    "express-rate-limit": "^7.1.5",
    "pg": "^8.13.0",
    "resend": "^6.9.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}
