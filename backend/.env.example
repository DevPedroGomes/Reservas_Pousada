# ===========================================
# CONFIGURACOES DO SERVIDOR
# ===========================================
NODE_ENV=development
PORT=4000

# ===========================================
# POSTGRESQL - BANCO DE DADOS DIRETO
# ===========================================
# Formato: postgresql://usuario:senha@host:porta/banco
DATABASE_URL=postgresql://postgres:password@localhost:5432/reservas_pousada

# ===========================================
# BETTER AUTH - AUTENTICACAO
# ===========================================
# IMPORTANTE: Use uma string aleatoria de pelo menos 32 caracteres
# Gere uma com: openssl rand -base64 32
BETTER_AUTH_SECRET=sua-chave-secreta-muito-longa-minimo-32-caracteres

# URL base do backend (usado para callbacks OAuth)
BETTER_AUTH_URL=http://localhost:4000

# ===========================================
# GOOGLE OAUTH
# ===========================================
# Obtenha as credenciais em: https://console.cloud.google.com/
# 1. Crie um projeto ou selecione um existente
# 2. Vá em "APIs & Services" > "Credentials"
# 3. Crie uma "OAuth 2.0 Client ID" para aplicacao Web
# 4. Configure as origens autorizadas: http://localhost:3000, http://localhost:4000
# 5. Configure os URIs de redirecionamento: http://localhost:4000/api/auth/callback/google

GOOGLE_CLIENT_ID=seu-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-sua-google-client-secret

# ===========================================
# CORS - ORIGENS PERMITIDAS
# ===========================================
# URL do frontend
CORS_ORIGIN=http://localhost:3000
